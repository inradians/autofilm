# ============================================================================
# autofilm — API keys (Runway-consolidated stack, May 2026)
# ============================================================================
# Copy to .env and fill in. Never commit .env.
#
# Three required, one optional. The Runway migration collapsed what was
# five separate providers (OpenAI for GPT Image 2, Google AI for Nano
# Banana 2 + Veo 3.1, ElevenLabs for SFX, plus Anthropic and Stability)
# down to three: Anthropic, Runway, Stability. Google AI is now optional —
# it only powers the long-video critic in evaluate.py, and you can run
# without it on Claude-stills-only review.

# Claude Opus 4.7 — script parsing, casting, lookbook, edit decisions,
# critic-stills review. Prepaid credits. ~$5 per default-size experiment.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Runway — image, video, and SFX generation in one API. Drives:
#   • image:    gpt_image_2, gemini_image3_pro (Nano Banana), gen4_image, gen4_image_turbo, gemini_2.5_flash
#   • video:    veo3.1, veo3.1_fast, gen4.5, gen4_turbo, gen4_aleph (v2v), seedance2
#   • SFX/TTS:  eleven_text_to_sound_v2, eleven_multilingual_v2
# Prepaid credits at $0.01/credit. ~$22 per default-size experiment (Veo
# dominates). Get the key at https://dev.runwayml.com/. The skill helpers
# in .claude/skills/ use this same env var name (RUNWAYML_API_SECRET).
RUNWAYML_API_SECRET=key_...

# Stability — Stable Audio 2.5 for cinematic music cues. Up to 47s per
# generation, instrumental. Prepaid credits, $10 minimum top-up.
# ~$1 per experiment.
STABILITY_API_KEY=sk-...

# Black Forest Labs — FLUX.1 T2I for celebrity reference image generation.
# FLUX is the only T2I model with celebrities in its training data that
# generates accurate likenesses from names alone. Used in both steps of
# the reference image pipeline (composition + identity lock).
# Get key at https://api.bfl.ml/ (pay-as-you-go, ~$0.05/image flux-pro-1.1)
BFL_API_KEY=

# OPTIONAL — Google AI Studio for Gemini 3 Pro long-video critic only.
# When set, evaluate_film() runs both reviewers (Gemini on the video,
# Claude on stills) and averages. When unset, evaluate.py warns and
# falls back to Claude-stills-only review with no impact on whether
# the pipeline runs. Veo 3.1 is now reached via Runway so you no
# longer need a Google Cloud billing account just for video.
GOOGLE_AI_API_KEY=

# ============================================================================
# Pipeline configuration (override defaults)
# ============================================================================

# Source book
BOOK_PDF_PATH=/mnt/user-data/uploads/JurassicPark-MichaelCrichton.pdf

# Render budget per experiment (these cap cost)
MAX_SCENES=3
SHOT_DURATION_SECONDS=8     # Veo's hard cap; valid options are 4, 6, 8.
                            # Seedance2 lifts this to 15s — set tier accordingly.
TAKES_PER_SHOT=1            # bump to 2-3 to give the editor options (more $)
VEO_TIER=fast               # fast | standard | gen4.5 | seedance2 | previs
VEO_RESOLUTION=720p         # 720p | 1080p (1080p only on Veo tiers)

# Optional ambient SFX layer. Off by default — Veo's native synced audio
# plus the Stable Audio music cue already give you a complete scene mix.
# When ON, an ambient bed (rain, jungle, room tone) is generated per
# scene via Runway's eleven_text_to_sound_v2 endpoint and layered under
# dialogue + music at -16 dB. Adds ~$1/run in Runway credits.
AMBIENT_SFX_ENABLED=0

# ============================================================================
# Optional creative direction
# ============================================================================
# Name a real working director and/or cinematographer whose body of work
# should bias the look book. Leave blank for the pipeline's neutral default.
# When set, the lookbook stage derives concrete craft markers (lens choice,
# lighting approach, palette, framing patterns) and bakes them into the
# prompts; the bible cover shows them as credits.
DIRECTOR=
CINEMATOGRAPHER=

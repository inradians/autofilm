# ============================================================================
# autofilm — API keys (SOTA stack, April 2026)
# ============================================================================
# Copy to .env and fill in. Never commit .env.
#
# Four required, one optional. All five providers are pay-as-you-go or
# prepaid; only ElevenLabs uses a monthly subscription, and it can be
# skipped entirely for a weekend run.

# Claude Opus 4.7 - script parsing, casting, lookbook, edit, critic reviewer
# Prepaid credits. ~$5 per experiment.
ANTHROPIC_API_KEY=sk-ant-...

# GPT Image 2 - first-frame composition, lookbook style frame
# Prepaid credits. ~$3 per experiment. Image gen needs your account
# (called an "Organization" in OpenAI's UI even for solo devs) verified.
OPENAI_API_KEY=sk-proj-...

# Single key drives Nano Banana 2 + Veo 3.1 (Lite/Fast/Standard) + Gemini 3 Pro
# Pay-as-you-go via Cloud billing. ~$18 per experiment (Veo dominates).
GOOGLE_AI_API_KEY=AIza...

# Stable Audio 2.5 - cinematic music cues
# Prepaid credits, $10 minimum top-up. ~$1 per experiment.
STABILITY_API_KEY=sk-...

# OPTIONAL: ElevenLabs ambient SFX beds. Subscription tier (cancellable).
# Leave blank to skip the ambient layer entirely — Veo's native synced
# audio + Stable Audio music already give you a complete scene mix.
ELEVENLABS_API_KEY=

# ============================================================================
# Pipeline configuration (override defaults)
# ============================================================================

# Source book
BOOK_PDF_PATH=/mnt/user-data/uploads/JurassicPark-MichaelCrichton.pdf

# Render budget per experiment (these cap cost)
MAX_SCENES=3
SHOT_DURATION_SECONDS=8     # Veo's hard cap; valid options are 4, 6, 8
TAKES_PER_SHOT=1            # bump to 2-3 to give the editor options (more $)
VEO_TIER=fast               # fast | standard. standard is ~2.7x more expensive
VEO_RESOLUTION=720p         # 720p | 1080p

# ============================================================================
# Optional creative direction
# ============================================================================
# Name a real working director and/or cinematographer whose body of work
# should bias the look book. Leave blank for the pipeline's neutral default.
# When set, the lookbook stage derives concrete craft markers (lens choice,
# lighting approach, palette, framing patterns) and bakes them into the
# prompts; the bible cover shows them as credits.
DIRECTOR=
CINEMATOGRAPHER=
